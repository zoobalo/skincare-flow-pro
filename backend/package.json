{
  "name": "skinops-backend",
  "version": "1.0.0",
  "description": "Zoobalo backend — Drizzle ORM + PostgreSQL",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.12.19",
    "jose": "^6.2.3",
    "pg": "^8.13.3",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.11.13",
    "drizzle-kit": "^0.29.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  }
}
